---
pagination:
  data: languages.codes
  size: 1
  alias: langCode
permalink: "{{ langCode }}/indices/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ 'indicesPageTitle' | t }}"
---

<p class="list-summary">{{ "indicesIntro" | t }}</p>

<div class="indices-grid">
{% if indices._summary and indices._summary.indices %}
    {% for idx in indices._summary.indices %}
    {% if idx.nav == "indices" or not idx.nav %}
    <a href="/{{ page.lang }}/indices/{{ idx.id }}/" class="index-card">
        <h3>{{ idx.title[page.lang] | default(idx.title.en) }}</h3>
        {% if idx.description %}
        <p>{{ idx.description[page.lang] | default(idx.description.en) }}</p>
        {% endif %}
        <span class="entry-count">{{ idx.entryCount }} {{ "entries" | t }}</span>
    </a>
    {% endif %}
    {% endfor %}
{% else %}
    <p>{{ "noIndices" | t }}</p>
{% endif %}
</div>
