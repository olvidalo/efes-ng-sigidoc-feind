---
pagination:
  data: languages.codes
  size: 1
  alias: langCode
permalink: "{{ langCode }}/search/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ 'searchPageTitle' | t }}"
---

<link rel="stylesheet" href="/assets/efes-search/efes-search.css">
<script type="module" src="/assets/efes-search/efes-search.js"></script>

{% set searchDataUrl = "/search-data/documents_" + page.lang + ".json" %}
<efes-search data-url="{{ searchDataUrl | url }}" text-fields="fullText,title" match-mode="substring">
    <aside class="efes-facet-sidebar">
        <h2>{{ "filterResults" | t }}</h2>

        <efes-date-range
            label="{{ "dateRange" | t }}"
            from-label="{{ "fromYear" | t }}"
            to-label="{{ "toYear" | t }}"></efes-date-range>

        <efes-facet field="language" label="{{ "language" | t }}" expanded></efes-facet>
        <efes-facet field="personalNames" label="{{ "personalNames" | t }}"></efes-facet>
        <efes-facet field="familyNames" label="{{ "familyNames" | t }}"></efes-facet>
        <efes-facet field="gender" label="{{ "gender" | t }}"></efes-facet>
        <efes-facet field="milieu" label="{{ "milieu" | t }}" expanded></efes-facet>
        <efes-facet field="placeNames" label="{{ "placeNames" | t }}" expanded></efes-facet>
        <efes-facet field="dignities" label="{{ "dignities" | t }}"></efes-facet>
        <efes-facet field="civilOffices" label="{{ "civilOffices" | t }}"></efes-facet>
        <efes-facet field="ecclesiasticalOffices" label="{{ "ecclesiasticalOffices" | t }}"></efes-facet>
        <efes-facet field="militaryOffices" label="{{ "militaryOffices" | t }}"></efes-facet>
        <efes-facet field="metrical" label="{{ "metrical" | t }}"></efes-facet>
        <efes-facet field="monogram" label="{{ "monogram" | t }}"></efes-facet>

        <div class="efes-filter-actions">
            <button data-action="clear-all">{{ "clearAll" | t }}</button>
        </div>
    </aside>

    <div class="efes-search-main">
        <efes-search-input placeholder="{{ "placeholder" | t }}"></efes-search-input>

        <efes-active-filters></efes-active-filters>

        <div class="efes-results-bar">
            <span class="efes-results-status">
                <efes-result-count
                        template="{{ "resultCount" | t }}" filtered-template="{{  "resultCountFiltered" | t }}"></efes-result-count>
            </span>
            <span class="efes-sort-label">{{ "sortBy" | t }}</span>
            <efes-sort>
                <field key="sortKey">{{ "sealId" | t }}</field>
                <field key="dateNotBefore" numeric>{{ "earliestDate" | t }}</field>
                <field key="dateNotAfter" numeric>{{ "latestDate" | t}}</field>
                <field key="title">{{ "title" | t }}</field>
            </efes-sort>
        </div>

        {% set resultBaseUrl = "/" + page.lang + "/seals/{documentId}/" %}
        <efes-results result-url="{{ resultBaseUrl | url }}">
            <template>
                <a>
                    <span class="doc-id" data-field="documentId"></span>
                    <span data-field="title"></span>
                </a>
                <div class="efes-result-details">
                    <span data-field="origDate"></span>
                    <span data-field="placeNames"></span>
                </div>
            </template>
        </efes-results>
    </div>
</efes-search>
