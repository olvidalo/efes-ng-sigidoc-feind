{# Data-driven index table partial
   Usage:
     {% set documentBasePath = "/en/inscriptions" %}
     {% set indexData = indices.persons %}
     {% include "partials/index-table.njk" %}
   Requires:
     indexData — object with { columns, entries, description }
     documentBasePath — base URL for document links (e.g. "/en/seals", "/de/seals")
#}

{% if indexData %}
    {% if indexData.description %}
    <p class="index-intro">{{ indexData.description[page.lang] | default(indexData.description.en) }}</p>
    {% endif %}

    {% macro renderTable(entries, columns, basePath) %}
    <table class="data-table index-table">
        <thead>
            <tr>
                {% for col in columns %}
                <th>{{ col.header[page.lang] | default(col.header.en) }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
        {% for entry in entries %}
            <tr>
                {% for col in columns %}
                    {% if col.type == 'references' %}
                        <td class="references">
                            {% for ref in entry.references %}
                                <a href="{{ basePath }}/{{ ref.documentId }}/">{{ ref.documentId }}</a>
                                {%- if not loop.last %} {% endif %}
                            {% endfor %}
                        </td>
                    {% elif col.type == 'link' %}
                        {% set val = entry[col.key] %}
                        {% if val %}
                            {% set linkVal = val[page.lang] if val[page.lang] else (val.en if val.en else val) %}
                            {% if linkVal and linkVal.url %}
                                <td><a href="{{ linkVal.url }}">{{ linkVal.label | default(linkVal.url) }}</a></td>
                            {% else %}
                                <td>-</td>
                            {% endif %}
                        {% else %}
                            <td>-</td>
                        {% endif %}
                    {% else %}
                        {% set val = entry[col.key] %}
                        {% if val is string or val is number %}
                            <td>{{ val | default('-') }}</td>
                        {% elif val %}
                            <td>{{ val[page.lang] | default(val.en) | default(val | dictsort | first | last) | default('-') }}</td>
                        {% else %}
                            <td>-</td>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endmacro %}

    <p class="entry-count-info">{{ indexData.entries | length }} entries</p>
    {{ renderTable(indexData.entries, indexData.columns, documentBasePath) }}
{% else %}
    <p>No index data available.</p>
{% endif %}
