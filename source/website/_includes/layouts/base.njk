<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default('SigiDoc Collection') }}</title>

    <!-- Foundation 4.3.1 — required for XSLT-generated tabs and grid markup -->
    <link rel="stylesheet" href="/assets/vendor/foundation/normalize-4.3.1.min.css">
    <link rel="stylesheet" href="/assets/vendor/foundation/foundation-4.3.1.min.css">

    <link rel="stylesheet" href="/assets/fonts/fonts.css">
    <link rel="stylesheet" href="/assets/css/base.css">
    <link rel="stylesheet" href="/assets/css/epidoc.css">
    <link rel="stylesheet" href="/assets/css/project.css">
    <script src="/assets/vendor/foundation/modernizr-2.6.2.min.js"></script>
</head>
<body>
{% include "header.njk" %}

<div class="layout-grid">
    {% if not suppressTitle %}
    <h1>{{ title }}</h1>
    {% endif %}

    <main>
        {{ content | safe }}
    </main>
</div>

{% include "footer.njk" %}

<!-- jQuery + Foundation JS — required for XSLT-generated tabs and RTI viewer -->
<script src="/assets/vendor/foundation/jquery-1.10.2.min.js"></script>
<script src="/assets/vendor/foundation/foundation-4.3.1.min.js"></script>
<script>
    $(document).foundation();
</script>
</body>
</html>
