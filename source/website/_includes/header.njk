<header>
    <div class="header-inner">
        <div class="header-content">
            <a href="/{{ page.lang }}/" class="site-title-link">
                <span class="site-title-abbr">SigiDoc</span>
                <span class="title-separator"></span>
                <span class="site-title-full">Sammlung Robert Feind</span>
            </a>

            <nav class="site-nav">
                {% set pathAfterLang = page.url | replace('/' + page.lang + '/', '/') %}
                <a href="/{{ page.lang }}/seals/" class="nav-link{% if pathAfterLang.startsWith('/seals/') %} nav-active{% endif %}">{{ "seals" | t }}</a>
                <div class="nav-dropdown">
                    <a href="/{{ page.lang }}/indices/" class="nav-link nav-dropdown-toggle{% if pathAfterLang.startsWith('/indices/') %} nav-active{% endif %}">{{ "indices" | t }}</a>
                    <ul class="nav-dropdown-menu">
                        {% if indices and indices._summary and indices._summary.indices %}
                            {% for idx in indices._summary.indices %}
                            {% if idx.nav == "indices" or not idx.nav %}
                            <li><a href="/{{ page.lang }}/indices/{{ idx.id }}/">{{ idx.title[page.lang] | default(idx.title.en) }}</a></li>
                            {% endif %}
                            {% endfor %}
                        {% endif %}
                    </ul>
                </div>
                <a href="/{{ page.lang }}/bibliography/" class="nav-link{% if pathAfterLang.startsWith('/bibliography/') %} nav-active{% endif %}">{{ "bibliography" | t }}</a>
                <a href="/{{ page.lang }}/search/" class="nav-link{% if pathAfterLang.startsWith('/search/') %} nav-active{% endif %}">{{ "search" | t }}</a>
            </nav>

            <nav class="language-switcher">
                {% for lang in languages.codes %}
                    {% if lang == page.lang %}
                        <span class="lang-current">{{ languages.labels[lang] }}</span>
                    {% else %}
                        <a href="{{ page.url | replace('/' + page.lang + '/', '/' + lang + '/') }}" class="lang-link">{{ languages.labels[lang] }}</a>
                    {% endif %}
                {% endfor %}
            </nav>
        </div>
    </div>
</header>
