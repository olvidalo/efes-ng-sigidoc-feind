<?xml version="1.0" encoding="UTF-8"?>
<!--
    Project-specific XSLT overrides for SigiDoc Feind.

    Templates here override upstream SigiDoc stylesheet templates
    by XSLT import precedence — this file is imported after the upstream
    stylesheets, so matching templates here take priority.

    Use this when the upstream stylesheets produce output that doesn't
    match your project's needs. Add template overrides here instead of
    editing the upstream code directly, so upstream updates can be
    applied without conflicts.

    See the IRCyr example project for documented override examples.
-->
<xsl:stylesheet version="3.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:t="http://www.tei-c.org/ns/1.0"
    exclude-result-prefixes="t">

    <!-- Add template overrides here. -->

</xsl:stylesheet>
