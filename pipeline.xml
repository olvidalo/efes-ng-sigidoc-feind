<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="efes-ng.rng" type="application/xml" schematypens="http://relaxng.org/ns/structure/1.0"?>
<pipeline xmlns="urn:efes-ng:pipeline" name="SigiDoc Feind">

  <meta siteDir="_output"/>

  <!-- Authority files referenced by XSLT document() calls -->
  <variable name="geography-file"><files>source/authority/geography.xml</files></variable>
  <variable name="dignities-file"><files>source/authority/dignities.xml</files></variable>
  <variable name="offices-file"><files>source/authority/offices.xml</files></variable>
  <variable name="invocations-file"><files>source/authority/invocation.xml</files></variable>
  <variable name="bibliography-file"><files>source/authority/bibliography.xml</files></variable>

  <copyFiles name="copy-eleventy-site">
    <sourceFiles><files>source/website/**/*</files></sourceFiles>
    <output to="_assembly" stripPrefix="source/website"/>
  </copyFiles>

  <!-- ===== LANGUAGE PRUNING ===== -->

  <xsltTransform name="prune-epidoc-english">
    <sourceFiles><files>source/feind-collection/*.xml</files></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/prune-to-language.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="language">en</param>
    </stylesheetParams>
  </xsltTransform>

  <xsltTransform name="prune-epidoc-german">
    <sourceFiles><files>source/feind-collection/*.xml</files></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/prune-to-language.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="language">de</param>
    </stylesheetParams>
  </xsltTransform>

  <xsltTransform name="prune-epidoc-greek">
    <sourceFiles><files>source/feind-collection/*.xml</files></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/prune-to-language.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="language">el</param>
    </stylesheetParams>
  </xsltTransform>

  <!-- ===== HTML RENDERING ===== -->

  <xsltTransform name="transform-epidoc-en">
    <sourceFiles><from node="prune-epidoc-english" output="transformed"/></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/epidoc-to-html.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="edn-structure">sigidoc</param>
      <param name="edition-type">interpretive</param>
      <param name="external-app-style">iospe</param>
      <param name="internal-app-style">none</param>
      <param name="leiden-style">sigidoc</param>
      <param name="line-inc">1</param>
      <param name="verse-lines">off</param>
      <param name="bibloc"><ref name="bibliography-file"/></param>
      <param name="bib-link-template">../../bibliography/$1/</param>
      <param name="language">en</param>
      <param name="messages-file"><files>source/translations/messages_en.xml</files></param>
    </stylesheetParams>
    <output to="_assembly/en/seals"
            stripPrefix="source/feind-collection"
            extension=".html"/>
  </xsltTransform>

  <xsltTransform name="transform-epidoc-de">
    <sourceFiles><from node="prune-epidoc-german" output="transformed"/></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/epidoc-to-html.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="edn-structure">sigidoc</param>
      <param name="edition-type">interpretive</param>
      <param name="external-app-style">iospe</param>
      <param name="internal-app-style">none</param>
      <param name="leiden-style">sigidoc</param>
      <param name="line-inc">1</param>
      <param name="verse-lines">off</param>
      <param name="bibloc"><ref name="bibliography-file"/></param>
      <param name="bib-link-template">../../bibliography/$1/</param>
      <param name="language">de</param>
      <param name="messages-file"><files>source/translations/messages_de.xml</files></param>
    </stylesheetParams>
    <output to="_assembly/de/seals"
            stripPrefix="source/feind-collection"
            extension=".html"/>
  </xsltTransform>

  <xsltTransform name="transform-epidoc-el">
    <sourceFiles><from node="prune-epidoc-greek" output="transformed"/></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/epidoc-to-html.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="edn-structure">sigidoc</param>
      <param name="edition-type">interpretive</param>
      <param name="external-app-style">iospe</param>
      <param name="internal-app-style">none</param>
      <param name="leiden-style">sigidoc</param>
      <param name="line-inc">1</param>
      <param name="verse-lines">off</param>
      <param name="bibloc"><ref name="bibliography-file"/></param>
      <param name="bib-link-template">../../bibliography/$1/</param>
      <param name="language">el</param>
      <param name="messages-file"><files>source/translations/messages_el.xml</files></param>
    </stylesheetParams>
    <output to="_assembly/el/seals"
            stripPrefix="source/feind-collection"
            extension=".html"/>
  </xsltTransform>

  <!-- ===== METADATA EXTRACTION (single node, all languages) ===== -->

  <xsltTransform name="extract-epidoc-metadata">
    <sourceFiles><files>source/feind-collection/*.xml</files></sourceFiles>
    <stylesheet><files>source/metadata-config.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="languages">en de el</param>
      <param name="geography-file"><ref name="geography-file"/></param>
      <param name="dignities-file"><ref name="dignities-file"/></param>
      <param name="offices-file"><ref name="offices-file"/></param>
      <param name="invocations-file"><ref name="invocations-file"/></param>
      <param name="bibliography-file"><ref name="bibliography-file"/></param>
    </stylesheetParams>
  </xsltTransform>

  <!-- ===== SIDECAR DATA ===== -->

  <xsltTransform name="generate-eleventy-data-en">
    <sourceFiles><from node="extract-epidoc-metadata" output="transformed"/></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/create-11ty-data.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="layout">layouts/document.njk</param>
      <param name="tags">seals-en</param>
      <param name="language">en</param>
    </stylesheetParams>
    <output to="_assembly/en/seals"
            stripPrefix="source/feind-collection"
            extension=".11tydata.json"/>
  </xsltTransform>

  <xsltTransform name="generate-eleventy-data-de">
    <sourceFiles><from node="extract-epidoc-metadata" output="transformed"/></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/create-11ty-data.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="layout">layouts/document.njk</param>
      <param name="tags">seals-de</param>
      <param name="language">de</param>
    </stylesheetParams>
    <output to="_assembly/de/seals"
            stripPrefix="source/feind-collection"
            extension=".11tydata.json"/>
  </xsltTransform>

  <xsltTransform name="generate-eleventy-data-el">
    <sourceFiles><from node="extract-epidoc-metadata" output="transformed"/></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/create-11ty-data.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="layout">layouts/document.njk</param>
      <param name="tags">seals-el</param>
      <param name="language">el</param>
    </stylesheetParams>
    <output to="_assembly/el/seals"
            stripPrefix="source/feind-collection"
            extension=".11tydata.json"/>
  </xsltTransform>

  <!-- ===== INDEX AGGREGATION ===== -->

  <xsltTransform name="aggregate-indices">
    <stylesheet><files>source/stylesheets/lib/aggregate-indices.xsl</files></stylesheet>
    <initialTemplate>aggregate</initialTemplate>
    <stylesheetParams>
      <param name="metadata-files"><from node="extract-epidoc-metadata" output="transformed"/></param>
      <param name="metadata-config"><files>source/metadata-config.xsl</files></param>
    </stylesheetParams>
    <output to="_assembly/_data/indices" filename="_summary.json"/>
  </xsltTransform>

  <!-- ===== SEARCH DATA (per language) ===== -->

  <xsltTransform name="aggregate-search-data-en">
    <stylesheet><files>source/stylesheets/lib/aggregate-search-data.xsl</files></stylesheet>
    <initialTemplate>aggregate</initialTemplate>
    <stylesheetParams>
      <param name="metadata-files"><from node="extract-epidoc-metadata" output="transformed"/></param>
      <param name="language">en</param>
    </stylesheetParams>
    <output to="_assembly/search-data" filename="documents_en.json"/>
  </xsltTransform>

  <xsltTransform name="aggregate-search-data-de">
    <stylesheet><files>source/stylesheets/lib/aggregate-search-data.xsl</files></stylesheet>
    <initialTemplate>aggregate</initialTemplate>
    <stylesheetParams>
      <param name="metadata-files"><from node="extract-epidoc-metadata" output="transformed"/></param>
      <param name="language">de</param>
    </stylesheetParams>
    <output to="_assembly/search-data" filename="documents_de.json"/>
  </xsltTransform>

  <xsltTransform name="aggregate-search-data-el">
    <stylesheet><files>source/stylesheets/lib/aggregate-search-data.xsl</files></stylesheet>
    <initialTemplate>aggregate</initialTemplate>
    <stylesheetParams>
      <param name="metadata-files"><from node="extract-epidoc-metadata" output="transformed"/></param>
      <param name="language">el</param>
    </stylesheetParams>
    <output to="_assembly/search-data" filename="documents_el.json"/>
  </xsltTransform>

  <!-- ===== FINAL ASSEMBLY ===== -->

  <eleventyBuild name="eleventy-build">
    <sourceDir><collect>_assembly</collect></sourceDir>
    <output to="_output"/>
  </eleventyBuild>

</pipeline>
